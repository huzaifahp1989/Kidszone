{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/reset-monthly",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/send-scheduled-pushes",
      "schedule": "0 * * * *"
    }
  ]
}
